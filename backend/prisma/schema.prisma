generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleType {
  VAN
  TRUCK
  MINI
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverCategory {
  LMV
  HMV
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  IN_SHOP
  COMPLETED
}

enum ExpenseStatus {
  PENDING
  APPROVED
  PAID
}

model User {
  id                  Int       @id @default(autoincrement())
  email               String    @unique
  passwordHash        String
  displayName         String?
  role                UserRole
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  createdTrips  Trip[]  @relation("TripCreatedBy")
  driverProfile Driver?
}

model Vehicle {
  id              Int           @id @default(autoincrement())
  regNo           String        @unique
  modelName       String
  type            VehicleType
  capacityKg      Decimal       @db.Decimal(10, 2)
  odometerKm      Decimal       @default(0) @db.Decimal(12, 2)
  acquisitionCost Decimal       @default(0) @db.Decimal(14, 2)
  status          VehicleStatus @default(AVAILABLE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  trips              Trip[]
  maintenanceRecords MaintenanceRecord[]
  fuelLogs           FuelLog[]
  expenses           Expense[]

  @@index([status])
  @@index([type])
}

model Driver {
  id            Int            @id @default(autoincrement())
  userId        Int?           @unique // set only if this driver has a login account
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  name          String
  licenseNo     String         @unique
  category      DriverCategory
  licenseExpiry DateTime
  contact       String?
  isActive      Boolean        @default(true)
  safetyScore   Int            @default(100)
  status        DriverStatus   @default(AVAILABLE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  trips Trip[]

  @@index([status])
}

model Trip {
  id                Int        @id @default(autoincrement())
  tripCode          String     @unique // e.g. TR001
  source            String
  destination       String
  vehicleId         Int?
  vehicle           Vehicle?   @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  driverId          Int?
  driver            Driver?    @relation(fields: [driverId], references: [id], onDelete: Restrict)
  cargoWeightKg     Decimal    @db.Decimal(10, 2)
  plannedDistanceKm Decimal?   @db.Decimal(10, 2)
  actualDistanceKm  Decimal?   @db.Decimal(10, 2)
  status            TripStatus @default(DRAFT)
  etaMinutes        Int?
  dispatchedAt      DateTime?
  completedAt       DateTime?
  cancelledReason   String?
  remarks           String?
  createdById       Int?
  createdBy         User?      @relation("TripCreatedBy", fields: [createdById], references: [id])
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  fuelLogs FuelLog[]
  expenses Expense[]
  revenue  TripRevenue?

  @@index([status])
  @@index([vehicleId])
  @@index([driverId])
  @@index([createdAt])
}

model MaintenanceRecord {
  id          Int               @id @default(autoincrement())
  vehicleId   Int
  vehicle     Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  serviceType String
  cost        Decimal           @default(0) @db.Decimal(12, 2)
  serviceDate DateTime          @default(now())
  status      MaintenanceStatus @default(IN_SHOP)
  notes       String?
  completedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([vehicleId])
}

model FuelLog {
  id         Int      @id @default(autoincrement())
  vehicleId  Int
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  tripId     Int?
  trip       Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)
  logDate    DateTime @default(now())
  odometerKm Decimal  @db.Decimal(12, 2)
  liters     Decimal  @db.Decimal(10, 2)
  fuelCost   Decimal  @db.Decimal(12, 2)
  remarks    String?
  createdAt  DateTime @default(now())

  @@index([vehicleId])
  @@index([tripId])
}

model Expense {
  id                 Int           @id @default(autoincrement())
  tripId             Int
  trip               Trip          @relation(fields: [tripId], references: [id], onDelete: Restrict)
  vehicleId          Int
  vehicle            Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  tollCost           Decimal       @default(0) @db.Decimal(12, 2)
  otherCost          Decimal       @default(0) @db.Decimal(12, 2)
  maintenanceCleared Boolean       @default(false)
  status             ExpenseStatus @default(PENDING)
  createdAt          DateTime      @default(now())

  @@index([tripId])
  @@index([vehicleId])
}

model TripRevenue {
  id        Int      @id @default(autoincrement())
  tripId    Int      @unique
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Restrict)
  revenue   Decimal  @default(0) @db.Decimal(14, 2)
  createdAt DateTime @default(now())
}
